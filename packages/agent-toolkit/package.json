{
  "name": "@mollie/agent-toolkit",
  "version": "0.1.0",
  "description": "Use Mollie in AI agent frameworks — OpenAI, LangChain, Vercel AI SDK",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openai": {
      "import": "./dist/adapters/openai.js",
      "types": "./dist/adapters/openai.d.ts"
    },
    "./langchain": {
      "import": "./dist/adapters/langchain.js",
      "types": "./dist/adapters/langchain.d.ts"
    },
    "./vercel-ai": {
      "import": "./dist/adapters/vercel-ai.js",
      "types": "./dist/adapters/vercel-ai.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts"
  },
  "keywords": [
    "mollie",
    "payments",
    "ai",
    "agent",
    "langchain",
    "openai",
    "vercel"
  ],
  "dependencies": {
    "mollie-api-typescript": "^1.12.8"
  },
  "peerDependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
